{
  "name": "@localhostlabs/hermes-qvac-provider",
  "version": "0.1.0-alpha.1",
  "description": "QVAC developer tooling package: hermes-qvac-provider",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "__init__.py",
    "dist",
    "docs",
    "examples",
    "qvac_provider/__init__.py",
    "scripts",
    "plugin.yaml",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "demo": "pnpm build && node examples/hermes-qvac-demo.mjs",
    "test": "vitest run",
    "test:python": "python3 -m unittest discover -s tests -p 'test_*.py'",
    "lint": "tsc -p tsconfig.json --noEmit",
    "verify:package": "bash scripts/verify-package.sh"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0"
  },
  "packageManager": "pnpm@11.10.0"
}
